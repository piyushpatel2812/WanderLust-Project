<style>

.navbar{
background:white;
z-index:1000;
}

/* SEARCH BUTTON */

.search-btn{
background-color:#fe424d;
color:#fff;
border-radius:25px;
padding:0 1rem;
}

.search-btn:hover{
background-color:#fe424d;
color:#fff;
}

.search-btn i{
display:inline;
margin-right:0.5rem;
}

/* search inp */

.search-inp{
border-radius:25px;
padding:0.5rem 3rem;
font-size:1rem;
}

/* navbar alignment */

.navbar-collapse{
align-items:center !important;
}
/* mobile responsive */

@media (max-width:768px){

.navbar-nav{
flex-direction:column !important;
text-align:center;
}

/* collapse menu style */

.navbar-collapse{
background:white;
padding:1rem;
border-radius:10px;
margin-top:0.5rem;
box-shadow:0 4px 10px rgba(0,0,0,0.1);
}

.search-bar{
width:100%;
margin-top:10px;
}

.search-inp{
width:100%;
padding:0.4rem 1rem;
}

.search-btn{
padding:0.4rem 0.8rem;
font-size:0.9rem;
margin-top:5px;
}

}

</style>



<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">

<div class="container-fluid">

<a class="navbar-brand" href="/listings">
<i class="fa-regular fa-compass"></i>
</a>

<button
class="navbar-toggler"
type="button"
data-bs-toggle="collapse"
data-bs-target="#navbarNavAltMarkup"
aria-controls="navbarNavAltMarkup">

<span class="navbar-toggler-icon"></span>

</button>



<div class="collapse navbar-collapse" id="navbarNavAltMarkup">

<!-- LEFT -->

<div class="navbar-nav">
<a class="nav-link" href="/listings">Explore</a>
</div>


<!-- SEARCH BAR -->

<div class="navbar-nav ms-auto search-bar">

<form class="d-flex" role="search" action="/listings/search" method="GET">

<input
class="form-control me-2 search-inp"
type="search"
name="search"
placeholder="Search destinations"
/>

<button class="btn search-btn" type="submit">

<i class="fa-solid fa-magnifying-glass"></i>
Search

</button>
</form>
</div>


<!-- LOGIN / LOGOUT -->

<div class="navbar-nav ms-auto">
<a class="nav-link" href="/listings/new">Airbnb your home</a>
<% if(!currUser){ %>
<a class="nav-link" href="/users/signup"><b>Signup</b></a>
<a class="nav-link" href="/users/login"><b>Log in</b></a>
<% } %>

<% if(currUser){ %>
<a class="nav-link" href="/users/logout"><b>Log out</b></a>
<% } %>

</div>
</div>
</div>
</nav>