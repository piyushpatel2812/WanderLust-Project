
<% layout("/layouts/boilerplate") %>

<script>
const mapToken = "<%= process.env.MAP_TOKEN %>";
const listing = <%- JSON.stringify(listing) %>;
</script>

<div class="row mt-3 justify-content-center">
<div class="col-lg-8 col-md-10 col-12">
<h3><%= listing.title %></h3>
<div class="card show-card listing-card">
<img
src="<%= listing.image.url %>"
class="card-img-top show-img img-fluid"
alt="listing_img">
<div class="card-body">
<p class="card-text">
Owned by <i><%= listing.owner?.username %></i>
</p>
<p><%= listing.description %></p>
<p>&#8377;<%= listing.price.toLocaleString("en-IN") %></p>
<p><%= listing.location %></p>
<p><%= listing.country %></p>
</div>
</div>
</div>
</div>


<% if(currUser && listing.owner && listing.owner._id.equals(currUser._id)){ %>

<div class="row justify-content-center mt-3">
<div class="col-lg-8 col-md-10 col-12 d-flex gap-3">
<a
href="/listings/<%= listing._id %>/edit"
class="btn btn-dark edit-btn">
Edit
</a>
<form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">

<button class="btn btn-dark">Delete</button>
</form>
</div>
</div>
<% } %>
<!--  booking form -->
<div class="row mt-4">

  <!-- LEFT -->
  <div class="col-md-7">
    <div class="card p-3">
      <h5>Select Dates</h5>
      <input type="text" id="dateRange" class="form-control" placeholder="Select Dates">
    </div>
  </div>

  <!-- RIGHT -->
  <div class="col-md-5">
    <div class="card p-3 shadow">

      <h4>₹<%= listing.price %> <small>per night</small></h4>
      <p id="totalPrice" class="mt-2 fw-bold text-success">Total: ₹0</p>

      <form action="/listings/<%= listing._id %>/book" method="POST">

        <input type="hidden" name="checkIn" id="checkIn">
        <input type="hidden" name="checkOut" id="checkOut">

        <button class="btn btn-danger w-100 mt-3">Reserve</button>

      </form>

    </div>
  </div>

</div>
<!-- REVIEW FORM -->

<div class="row justify-content-center">
<div class="col-lg-8 col-md-10 col-12 mb-3 mt-3">
<% if(currUser){ %>
<hr>
<h4>Leave a Review</h4>
<form
action="/listings/<%= listing._id %>/reviews"
method="POST"
novalidate
class="needs-validation">

<div class="mb-3 mt-3">
<label for="rating" class="form-label">Rating</label>
<fieldset class="starability-slot">

  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked />

<input type="radio" id="first-rate1" name="review[rating]" value="1" />
<label for="first-rate1">1 star</label>

<input type="radio" id="first-rate2" name="review[rating]" value="2" />
<label for="first-rate2">2 stars</label>

<input type="radio" id="first-rate3" name="review[rating]" value="3" />
<label for="first-rate3">3 stars</label>

<input type="radio" id="first-rate4" name="review[rating]" value="4" />
<label for="first-rate4">4 stars</label>

<input type="radio" id="first-rate5" name="review[rating]" value="5" />
<label for="first-rate5">5 stars</label>

</fieldset>

</div>

<div class="mb-3 mt-3">

<label for="comment" class="form-label">Comments</label>

<textarea
name="review[comment]"
id="comment"
rows="5"
class="form-control"
required></textarea>

<div class="invalid-feedback">

Please submit some comments for review

</div>

</div>


   <button class="btn btn-dark w-10">Submit</button>


</form>

<hr>

<% } %>



<!-- REVIEW CARDS -->

<% if(listing.reviews.length > 0){ %>

<div class="row">

<p><b>All Reviews</b></p>

<% for(review of listing.reviews){ %>

<div class="col-lg-4 col-md-6 col-12 mb-3">

<div class="card h-100">

<div class="card-body">

<h5 class="card-title ms-2">@<%= review.author.username %></h5>

<p class="starability-result ms-2" data-rating="<%= review.rating %>"></p>

<p class="card-text ms-2"><%= review.comment %></p>

<form
method="POST"
class="ms-2 mb-2"
action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">

<button class="btn btn-sm btn-dark w-10 ">Delete</button>

</form>

</div>

</div>

</div>

<% } %>

</div>

<% } %>

</div>

</div>



<!-- MAP -->

<div class="row justify-content-center">

<div class="col-lg-8 col-md-10 col-12 mb-3">

<h3>Where you'll be</h3>

<div id="map"></div>

</div>

</div>

<script src="/js/map.js"></script>